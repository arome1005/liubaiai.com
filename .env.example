# 前端 Supabase（Settings → API → Project URL / anon public）
# vite.config.ts 已设置 envDir: backend，可与 backend/.env 共用；也可在项目根单独放 .env.local
VITE_SUPABASE_URL=https://xxxx.supabase.co
VITE_SUPABASE_ANON_KEY=your_anon_key

# 忘记密码邮件：`authForgotPassword` 会重定向到 {origin}/reset-password
# 须在 Supabase → Authentication → URL Configuration 的 Redirect URLs 中加入：
#   http://localhost:5173/reset-password
#   以及生产环境 https://你的域名/reset-password

# 生产静态站未反代 /api 时必填，否则注册 POST 会 405（见 docs/生产环境部署.md）
# 示例：https://api.你的域名  （无末尾 /）
# VITE_API_BASE=
