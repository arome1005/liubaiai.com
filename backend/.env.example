DB_HOST=96.44.165.50
DB_PORT=56854
DB_USER=your_user
DB_PASSWORD=your_password
# 与 1Panel / psql 里实际连接的数据库名一致；你当前使用默认库可保持 postgres
DB_NAME=postgres
DB_SSL=false
API_PORT=8788
AUTH_JWT_SECRET=change-me
COOKIE_SECRET=change-me-too

# 注册验证码 HMAC（可与 AUTH_JWT_SECRET 不同；生产务必设置）
# OTP_HMAC_SECRET=

# 验证码有效期（毫秒）、重发间隔、每小时上限
# OTP_TTL_MS=600000
# OTP_RESEND_MS=60000
# OTP_MAX_PER_HOUR=5

# 发信：不设 SMTP 时走控制台日志（开发）；生产请配置 SMTP 或 MAIL_MODE=dev 仅本地调试
# MAIL_MODE=dev
# SMTP_HOST=
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASS=
# MAIL_FROM=

# 仅开发：在接口响应里返回 dev.code（勿用于生产）
# MAIL_DEV_RETURN_CODE=1
