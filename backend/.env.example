# Postgres：与 Supabase 项目使用同一数据库时，填 Supabase 提供的连接串（Settings → Database）
DB_HOST=your_db_host
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=your_password
DB_NAME=postgres
DB_SSL=true
API_PORT=8788

# 可选：额外允许的浏览器 Origin（逗号或空格分隔），生产主站已内置 www / 裸域
# CORS_ORIGINS=https://preview.xxx.vercel.app

# Supabase（后端：Admin API 建号 + 校验 access_token）
SUPABASE_URL=https://xxxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_service_role_secret

# 前端（vite.config 已设 envDir: backend，可与本文件共用；勿把 Service Role 写进 VITE_）
# Vercel/CI 构建时也要在面板注入同名变量，否则线上会提示「未配置 VITE_SUPABASE…」（见 docs/生产环境部署.md）
# VITE_SUPABASE_URL=https://xxxx.supabase.co
# VITE_SUPABASE_ANON_KEY=your_anon_public_key
# 生产：静态站没有把 /api 转到 Node 时，构建加 VITE_API_BASE=https://你的API域名 （无末尾 /）
#
# 忘记密码：Redirect URLs 需含 http://localhost:5173/reset-password 与生产 /reset-password（与 src/api/auth.ts 中 redirectTo 一致）

# 注册验证码 HMAC（生产务必设置）
# OTP_HMAC_SECRET=

# 验证码有效期（毫秒）、重发间隔、每小时上限
# OTP_TTL_MS=600000
# OTP_RESEND_MS=60000
# OTP_MAX_PER_HOUR=5

# 发信：注册 6 位验证码（不设 SMTP 时走控制台日志）
# MAIL_MODE=dev
# SMTP_HOST=
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASS=
# MAIL_FROM=

# 仅开发：在接口响应里返回 dev.code（勿用于生产）
# MAIL_DEV_RETURN_CODE=1

# 前端地址（部分邮件/重定向说明用）
# APP_PUBLIC_URL=http://localhost:5173

# ===== Vertex AI 代理（用于消耗 GCP 赠金；SA JSON 仅保存在后端，不要进 VITE_）=====
# 推荐用 base64 编码，避免 dotenv 把 private_key 里的 \n 解错：
#   cat sa.json | base64 | tr -d '\n'   # 然后整段贴到下面
# GOOGLE_VERTEX_SA_JSON_B64=
# 如不便用 base64，可改用原文（注意 .env 单行 + 转义）；优先级低于上面这条
# GOOGLE_VERTEX_SA_JSON=
# GCP project id（必填，例：my-vertex-proj）
# GOOGLE_VERTEX_PROJECT=
# 模型所在区域（默认 us-central1，覆盖最全）
# GOOGLE_VERTEX_LOCATION=us-central1
